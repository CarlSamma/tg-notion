# Telegram Bot Token (get from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Notion Integration Token (get from notion.so/my-integrations)
NOTION_TOKEN=your_notion_integration_token_here

# Anthropic API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Webhook secret for security (generate with: openssl rand -hex 20)
WEBHOOK_SECRET=your_random_secret_here

# Optional: Parent page ID where the database will be created
# Get this from the Notion page URL: https://www.notion.so/PAGE_ID?v=...
NOTION_PARENT_PAGE_ID=your_notion_page_id_here
